# ============================================================
# Secrets — copiar este archivo a .env y completar
# ============================================================
# .env NUNCA se commitea (ya está en .gitignore)
# Estos valores sobreescriben lo que haya en settings.yaml
# ============================================================

# --- SQL Server ---
DB_SERVER=tu-servidor\instancia
DB_DATABASE=nombre_base
# Si usás Windows Auth (Trusted Connection), dejá vacíos:
DB_USERNAME=
DB_PASSWORD=
# Si completás USERNAME y PASSWORD, se desactiva Windows Auth automáticamente.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google Sheets ---
# Ruta al JSON de la service account de Google Cloud
GOOGLE_CREDENTIALS_PATH=credentials.json
# ID del spreadsheet (sacalo de la URL: https://docs.google.com/spreadsheets/d/{ESTE_ID}/edit)
SPREADSHEET_ID=
